# Copy to application.properties for local development.
# On Render (or any cloud host), set these as environment variables instead —
# Spring Boot automatically maps SUPABASE_URL → supabase.url, etc.

# Supabase REST API
supabase.url=https://YOUR_PROJECT_ID.supabase.co
supabase.key=YOUR_SUPABASE_ANON_KEY

# Downstream service URLs (use Render internal URLs in production)
cart.service.url=http://localhost:3002
payment.service.url=http://localhost:3003

# Server
server.port=8080
